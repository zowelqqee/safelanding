FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    CITY_MODEL_PATH=/app/city_model.pt

WORKDIR /app

COPY requirements-model.txt ./
RUN pip install --no-cache-dir -r requirements-model.txt

COPY city_model.pt ./
COPY ml ./ml
COPY relocation_dataset ./relocation_dataset

EXPOSE 8000

CMD ["sh", "-c", "python3 -m ml.city_model_server --host 0.0.0.0 --port ${PORT:-8000}"]
